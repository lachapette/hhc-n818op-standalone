# Example of .env file to set up in your folder for development:

# copy this file into `.env` and set credentials and other configuration only
# applicable to your environment.

# The `.env` file is NOT commited in git.

# Docker configuration defaults
# Docker configuration - compatible with docker compose
CONTAINER_NAME=hhc_n818op
IMAGE_NAME=${CONTAINER_NAME}:latest
INSTALL_FOLDER_CLIENT=/usr/share/${CONTAINER_NAME}
CONTAINER_USER=hhc_n818op_user
CONTAINER_NETWORK=hhc_n818op_network
WRK_DOCKER_DIR=${WRK_DOCKER_DIR}
UID=$(id -u "${CONTAINER_USER}")
GID=$(id -g "${CONTAINER_USER}")
UID_GID_DEFAULT=1000
